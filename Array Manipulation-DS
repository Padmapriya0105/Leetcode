#include <stdio.h>
#include <stdlib.h>

long long arrayManipulation(int n, int m, int queries[m][3]) {
    // calloc initializes the array to 0
    long long* diff = (long long*)calloc(n + 2, sizeof(long long));
    
    for (int i = 0; i < m; i++) {
        int a = queries[i][0];
        int b = queries[i][1];
        int k = queries[i][2];
        
        diff[a] += k;
        if (b + 1 <= n) {
            diff[b + 1] -= k;
        }
    }
    
    long long maxVal = 0;
    long long currentSum = 0;
    for (int i = 1; i <= n; i++) {
        currentSum += diff[i];
        if (currentSum > maxVal) maxVal = currentSum;
    }
    
    free(diff);
    return maxVal;
}

int main() {
    int n, m;
    // Use scanf to read the input as provided by the judge
    if (scanf("%d %d", &n, &m) != 2) return 0;
    
    int queries[m][3];
    for (int i = 0; i < m; i++) {
        scanf("%d %d %d", &queries[i][0], &queries[i][1], &queries[i][2]);
    }
    
    // Output ONLY the number
    printf("%lld\n", arrayManipulation(n, m, queries));
    
    return 0;
}
